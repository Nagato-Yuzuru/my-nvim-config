" 设置语言环境为英文
set langmenu=en_US.UTF-8
language messages en_US.UTF-8

set mouse=

set cursorline
set number

" 行可视模式下使用 J/K 移动代码块
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv
" 初始化插件管理器
call plug#begin('~/.vim/plugged')

" 安装 nvim-treesitter 插件
Plug 'nvim-treesitter/nvim-treesitter', {'do': ':TSUpdate'}

" 安装 Tokyonight 配色方案
Plug 'folke/tokyonight.nvim'

Plug 'christoomey/vim-tmux-navigator'
Plug 'aserowy/tmux.nvim'
" cmp

Plug 'hrsh7th/nvim-cmp'
Plug 'hrsh7th/cmp-buffer'
Plug 'hrsh7th/cmp-path'
Plug 'hrsh7th/cmp-nvim-lsp'
Plug 'hrsh7th/cmp-nvim-lua'
Plug 'hrsh7th/cmp-cmdline'
Plug 'saadparwaiz1/cmp_luasnip'

Plug 'L3MON4D3/LuaSnip'
Plug 'onsails/lspkind.nvim'
call plug#end()

lua require('cmp-config') 
" 配置 nvim-treesitter
lua <<EOF
require'nvim-treesitter.configs'.setup {
  ensure_installed = { "python", "go", "html", "json", "yaml", "bash", "sql", "c", "cpp", "lua" },  -- 安装解析器
  highlight = {
    enable = true,  -- 启用语法高亮
  },
  indent = {
    enable = true,  -- 启用自动缩进
  },
}
EOF

" 设置 Tokyonight 配色方案
colorscheme tokyonight

highlight LineNr guifg=#dddddd
" highlight CursorLineNr guifg=#f0c674
highlight CursorLineNr guifg=#ff996c

lua <<EOF
require("tmux").setup({
    copy_sync = {
        enable = true,  -- 开启 Neovim 和 tmux 剪贴板同步
    },
    navigation = {
        enable_default_keybindings = true,  -- 默认快捷键（如 Ctrl-h/j/k/l 切换面板）
    },
})
EOF

