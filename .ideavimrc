" .ideavimrc is a configuration file for IdeaVim plugin. It uses
"   the same commands as the original .vimrc configuration.
" You can find a list of commands here: https://jb.gg/h38q75
" Find more examples here: https://jb.gg/share-ideavimrc

let mapleader = " "
let maplocalleader = ","
" Mirrors vim.g.maplocalleader = "," in ~/.config/nvim/init.lua — keeps
" <localleader>* bindings (git, typst, …) typeable as `,*` on both sides.
"" -- Suggested options --
" Show a few lines of context around the cursor. Note that this makes the
" text scroll if you mouse-click near the start or end of the window.

" Do incremental searching.
set incsearch
set surround
set multiple-cursors
set keep-english-in-normal
set easymotion
set commentary
set exchange
set argtextobj

" Don't use Ex mode, use Q for formatting.

" block comment

" multiple-cursors keymap
" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins
" Highlight copied text
Plug 'machakann/vim-highlightedyank'
Plug 'romainl/vim-cool'
Plug 'terryma/vim-multiple-cursors'
"" -- Emacs C-x prefix keymap
nnoremap <C-S-A> <C-x>
noremap <C-x> <Nop>
nmap K <Action>(QuickJavaDoc)

" -- Tab management asymmetry
" JetBrains 没有 vim 那种"tabpage = workspace 容器"的概念——IDE 的 tab 是
" file-level（≈ vim buffer），同一个项目窗口里所有 file tab 共享同一套 tool
" window 布局，没法像 vim 那样为每个 tab 维护独立的 split layout + 名字。
" 所以以下 nvim 侧的键位 IdeaVim 这边故意不绑：
"   <C-x>R    重命名当前 tab（lua/core/keymaps.lua，存在 t:tabname，bufferline
"             custom_areas 渲染）—— JetBrains 没有可命名的 workspace 单位，
"             最接近的是 Tool Window 布局存档（"Window > Store/Restore Layout"），
"             但语义不同，强行映射只会误导。
" tab 创建/切换那几个 (<C-x>T / <C-x><Tab> / <C-x><S-Tab> / <C-x>X) 同理：
" JetBrains 用 "New Window"（独立 IDE 窗口）和文件 tab 已经覆盖大部分场景。

" -- LSP hover / signature help: both sides use community defaults
" normal K          → Quick Documentation  (IdeaVim native)
" insert <C-k>      → ParameterInfo         (IDE, not intercepted by IdeaVim;
"                                            bind in IDE Keymap if the default
"                                            Cmd/Ctrl+P has been overridden)
" Mirror of lua/core/lsp.lua. Intentionally unbound here — nothing to do.

" -- easymotion



" Mirrors ~/.config/nvim/lua/plugins/edit/motion.lua (Flash.nvim).
" <leader><leader>t/T on the Neovim side is Flash Treesitter — intentionally
" left unbound here since IdeaVim has no equivalent node-based jump.

" Line direction (words, current line)
map <leader><leader>h <Plug>(easymotion-linebackward)
map <leader><leader>l <Plug>(easymotion-lineforward)

" Buffer-wide word (mirror of h/l, word = \k not \S+)
map <leader><leader>H <Plug>(easymotion-b)
map <leader><leader>L <Plug>(easymotion-w)

" Cross-line first-non-blank
map <leader><leader>j <Plug>(easymotion-j)
map <leader><leader>k <Plug>(easymotion-k)

" Line-scoped word motions
map <leader><leader>w <Plug>(easymotion-wl)
map <leader><leader>b <Plug>(easymotion-bl)
map <leader><leader>e <Plug>(easymotion-el)

" Buffer-wide WORD motions (non-whitespace blocks)
map <leader><leader>W <Plug>(easymotion-W)
map <leader><leader>B <Plug>(easymotion-B)
map <leader><leader>E <Plug>(easymotion-E)

" Incremental label jump (2-char / label search)
map <leader><leader>s <Plug>(easymotion-s2)
map <leader><leader>/ <Action>(AceAction)

" Repeat last jump
map <leader><leader>. <Plug>(easymotion-repeat)

nmap <Plug>(easymotion-prefix) <Nop>

map <A-n> <Action>(SelectNextOccurrence)
map <A-S-n> <Action>(SelectAllOccurrences)
map <A-x> <Action>(FindNextOccurrence)
map <A-p> <Action>(UnselectPreviousOccurrence)
" nvim-side asymmetry: <A-p> is also bound as a buffer-local "toggle preview popup"
" inside the snacks.explorer list (lua/plugins/ui/snacks.lua) and the trouble list
" (lua/plugins/ui/trouble.lua). Both are sidebar tools that don't exist as IdeaVim
" surfaces — JetBrains has its own Project tool window and Problems view — so there's
" no IDE Action to mirror here. Multi-cursor semantics are unaffected: those buffers
" don't accept multi-cursor anyway, so the buffer-local override is invisible outside
" them. Recorded here so the parity map stays a single source of truth for <A-p>.


map  <A-j>   <Action>(EditorCloneCaretBelow)
map  <A-k>   <Action>(EditorCloneCaretAbove)


nmap <leader>/ <Action>(FindInPath)
nmap <leader>, <Action>(RecentFiles)

" Structure / Outline — mirrors lua/plugins/ui/aerial.lua on the Neovim side.
" <leader>ns is the transient popup (Navigation extras namespace, no g* equivalent).
" The persistent sidebar lives at <leader>vs in section "3) Views" below — its
" semantics is "open a tool window", which is the Views-namespace contract.
nmap <leader>ns <Action>(FileStructurePopup)

" Search prefix <leader>s* is nvim-only (lua/plugins/ui/snacks.lua +
" lua/plugins/edit/rip-substitute.lua):
"   <leader>ss  → workspace symbols    — use Shift+Shift (Search Everywhere)
"   <leader>sc  → commands / actions   — use Shift+Shift, "Actions" tab
"   <leader>sk  → keymaps picker       — use Help → Find Action
"   <leader>sb  → buffer lines fuzzy   — use Ctrl+F (Find in File) + fuzzy mode
"   <leader>sB  → grep open buffers    — use Edit → Find → Find in Files (scope: open)
"   <leader>sw  → grep word/selection  — use Ctrl+Shift+F on cursor word
"   <leader>s/  → search history       — IDE keeps history in Find toolbar dropdown
"   <leader>sr  → rip-substitute       — use Ctrl+R (Replace) / Ctrl+Shift+R (in path)
" IdeaVim deliberately doesn't mirror these: Search Everywhere + native Find/
" Replace already cover the same ground with a single entry point, so
" duplicating them as leader bindings would just add noise.
"
" Note: nvim-side <leader>sr opens a PCRE2 popup substitution UI on top of
" vim's native :s (which gets inccommand=split preview). IDE side has no
" PCRE2-vs-vim split — Ctrl+R supports proper regex out of the box, so the
" two-entry-point design only exists on the nvim side.


"" -- map IDE actions to IdeaVim -- https://jb.gg/abva3t
"" Map \r to the Reformat Code action
"map \r <Action>(ReformatCode)
"" Map <leader>d to start debug
"map <leader>d <Action>(Debug)

"" IDE function map to ideavim

" 1)  Refactoring
" 需要在选中模式下工作的填写成map
" <leader>ca = quick-fixes + intentions + code actions (mirror of
" vim.lsp.buf.code_action in lua/core/lsp.lua). Kept outside <leader>r*
" because that namespace is reserved for deterministic refactorings.
map <leader>ca <Action>(ShowIntentionActions)
map <leader>R <Action>(RefactoringMenu)
map <leader>rn <Action>(RenameElement)
nmap <leader>rs <Action>(ChangeSignature)
map <leader>rv <Action>(IntroduceVariable)
map <leader>rc <Action>(IntroduceConstant)
map <leader>rf <Action>(IntroduceField)
map <leader>rm <Action>(ExtractMethod)
map <leader>ri <Action>(ExtractInterface)
map <leader>rl <Action>(Inline)
map <leader>rd <Action>(SafeDelete)
nmap <leader>rp <Action>(IntroduceParameter)
nmap <leader>rj <Action>(ConvertPythonToJupyterAction)
nmap <leader>rr <Action>(RefactorCode)
map <leader>rM <Action>(Move)


" 2) Navigation — aligned with Neovim/LSP community g* defaults.
" Overriding Vim natives here:
"   gi — "insert at last insert position" (use <C-o>i or `^i instead)
"   gr — virtual replace mode (use R for normal replace)
"   gD — search word in current file (use * / # instead)
" gd is already IdeaVim default (GotoDeclaration); declared here for symmetry.
nmap gd <Action>(GotoDeclaration)
nmap gD <Action>(GotoTypeDeclaration)
nmap gi <Action>(GotoImplementation)
nmap gr <Action>(FindUsages)
" gp* — preview namespace, mirrors lua/plugins/lsp/preview.lua (goto-preview).
"   gpd / gpD / gpi → preview definition / type-def / implementation in float
"   gpc             → close all preview windows (recursive stack panic-exit)
" IdeaVim side is intentionally unbound: JetBrains has the equivalent built in
" as Quick Definition Lookup (Opt+Space / Ctrl+Shift+I), which IdeaVim does
" NOT intercept — it works in any mode and doesn't need a leader binding. If
" the IDE default is rebound, fix it in IDE Keymap, not here.
" gpr (preview references) intentionally not bound on either side: references
" go through gr → FindUsages (IDE) / Trouble (nvim), which is better for
" browsing many candidates than a transient float.

" <leader>n* — extras that have no standard g* default:
"   nb  → supertypes / GotoSuperClass
"   nt  → GotoTest
"   nf  → FindInPath (search, not jump)
"   ns  → structure popup (transient; persistent sidebar moved to <leader>vs)
" GotoSuperMethod intentionally unbound: LSP's typeHierarchy only covers
" class-level, not method-level — keep parity with Neovim side.
"
" Asymmetry — Neovim only:
"   <leader>n{h,j,k,l} → treewalker.nvim AST walker (sticky hydra)
"     h=parent  j=next sibling  k=prev sibling  l=drill into child
"   No JetBrains equivalent — IDE has Move Statement Up/Down (Cmd+Shift+↑/↓)
"   for swap but no AST sibling/parent walk. Not bound here; reserve
"   <leader>n{h,j,k,l} on the IDE side for possible future use.
map <leader>nb <Action>(GotoSuperClass)
map <leader>nt <Action>(GotoTest)
map <leader>nf <Action>(FindInPath)

"3) Views

nmap <leader>vp <Action>(ActivateProjectToolWindow)
" Asymmetry: snacks.explorer on Neovim binds vim-fold-style z[oOcCaARM] inside
" the tree (lua/plugins/ui/snacks.lua). The JetBrains Project tool window uses
" the IDE's own keymap (Right/Left, NumPad +/-, Ctrl+NumPad+ for expand-all),
" which IdeaVim cannot intercept — leave it to the IDE keymap.
nmap <leader>vs <Action>(ActivateStructureToolWindow)
nmap <localleader>gd <Action>(Compare.SameVersion)
nmap <leader>vc <Action>(ActivateCommitToolWindow)
nmap <leader>vr <Action>(ActivateRunToolWindow)
nmap <leader>vd <Action>(ActivateDebugToolWindow)
nmap <leader>vt <Action>(ActivateTODOToolWindow)
nmap <leader>vP <Action>(ActivateProblemsViewToolWindow)
nmap <leader>vD <Action>(ToggleDistractionFreeMode)
nmap <leader>vF <Action>(ToggleFullScreen)
nmap <leader>vm <Action>(ActivateBookmarksToolWindow)
" Views panel toggles that mirror Neovim:
"   vp → Snacks.explorer            (lua/plugins/ui/snacks.lua)
"   vs → :AerialToggle!             (lua/plugins/ui/aerial.lua)
"   vr → :OverseerToggle            (lua/plugins/runtime/overseer.lua)
"   vd → require'dapui'.toggle      (lua/plugins/runtime/dap.lua)
"   vt → :TodoTrouble                (lua/plugins/ui/todo-comments.lua)
"        nvim 同时在 <leader>st 暴露 Snacks picker —— 心智模型是
"        "Search 用 picker / View 用 panel"。IdeaVim 这边没有 <leader>s*
"        命名空间（用 Search Everywhere 替代），所以只对齐 vt = panel。
"   vP → :Trouble diagnostics …     (lua/plugins/ui/trouble.lua)
"   vm → :BookmarksTree (alias of <leader>M) for cross-editor parity.
"        Canonical entry on the nvim side is <leader>M (master-singleton
"        convention: uppercase single letter = total/master menu, mirrors
"        <leader>R for refactoring). <leader>vm is an alias so JetBrains
"        muscle memory still works on the nvim side.
"        Picker form lives at <leader>sm (nvim-only — <leader>s* namespace
"        is nvim-only since IDE uses Search Everywhere; backed by telescope
"        due to LintaoAmons hard dep).
" Asymmetries (intentional, not bound on the nvim side):
"   vc  → Commit Tool Window  (nvim uses lazygit via <localleader>G instead)
"   vD  → Distraction Free    (no zen-mode plugin installed)
"   vF  → FullScreen          (terminal-multiplexer level — out of nvim scope)
" nvim-only extras with no IdeaVim equivalent:
"   vn  → Snacks.notifier.show_history  (lua/plugins/ui/snacks.lua)
"   vM  → toggle code minimap           (lua/plugins/ui/neominimap.lua)
"        On JetBrains the equivalent is the CodeGlance plugin (or built-in
"        Settings → Editor → General → Appearance → "Show code lens on the
"        scrollbar"); both render in the gutter outside IdeaVim's reach, so
"        no <leader>vM mirror here. Default-on on the nvim side to match
"        CodeGlance's always-visible behavior.
"   <C-x>m → toggle focus into/out of minimap (nvim-only; <C-x> chord prefix
"        is IDE-routed, see top-of-file note. JetBrains has no native
"        equivalent — minimap there isn't a focusable window.)


" 4)  Generate
map <leader>G <Action>(Generate)

" 8)  Git — <localleader>g* (low-frequency, tool-level ops)
nmap <localleader>G <Action>(Vcs.QuickListPopupAction)
nmap <localleader>gl <Action>(Vcs.ShowTabbedFileHistory)
map <leader>go <Action>(OverrideMethods)
map <leader>gi <Action>(ImplementMethods)
map <leader>gc <Action>(GoGenerateConstructorAction)
map <leader>gG <Action>(GoGenerateGetterAction)
map <leader>gS <Action>(GoGenerateSetterAction)
map <leader>gA <Action>(GoGenerateGetterSetterAction)
" map <leader>gt <Action>(GenerateToString)
map <leader>gd <Action>(GenerateDelegate)
map <leader>gt <Action>(SurroundWith)
map <leader>gT <Action>(SurroundWithLiveTemplate)
map <leader>gu <Action>(Unwrap)
map <leader>gJ <Action>(GoGenerateTypeFromJsonAction)
map <leader>gj <Action>(GoGenerateStructFieldsFromJsonAction)
map <leader>gf <Action>(GoGenerateFileAction)
map <leader>gm <Action>(GoGenerateMethodAction)
map <leader>gs <Action>(GoGenerateForStruct)
"" Map \b to toggle the breakpoint on the current line
"map \b <Action>(ToggleLineBreakpoint)
" 5)  Debug — mirrors lua/plugins/runtime/dap.lua (nvim-dap)
"
" Shared bindings (both sides):
nmap <leader>D <Action>(DebugMainMenu)
nmap <leader>db <Action>(ToggleLineBreakpoint)
map <leader>dB <Action>(BreakpointActionsGroup)
"
" nvim-only debug bindings (no IdeaVim equivalent — these are nvim-dap operations
" without IDE Action counterparts; on JetBrains use the IDE's native F-key
" keymap or the Debug Tool Window):
"   <leader>dc      Continue (same as <leader>D, namespace alias)
"   <leader>dn      Step over (next, like pdb/dlv `n`)
"   <leader>ds      Step into (step, like pdb/dlv `s`)
"   <leader>df      Step out  (finish, like dlv `f`)
"   <leader>dr      Toggle REPL
"   <leader>de      Inspect expression at cursor / visual
"   <leader>dh      Hover variable popup
"   <leader>dl      Run last debug session
"   <leader>dq      Terminate session
"   <leader>dj/dk   Frame down/up
"
" Step-key choice rationale: <leader>dn/ds/df mirror the n/s/f commands of
" pdb, dlv, and gdb (one mnemonic across CLI debuggers and the editor). On
" JetBrains the same operations are F8 / F7 / Shift-F8 via the IDE keymap.
" This asymmetry is intentional — see CLAUDE.md "Runtime suite" section.

" 5b) Test / Run — nvim-only namespace; on JetBrains the Run/Debug Tool
" Window + run configurations cover the same workflow.
"   <leader>tt   neotest run nearest        (IDE: gutter run icon / Ctrl-Shift-F10)
"   <leader>tT   neotest run file
"   <leader>tl   neotest run last
"   <leader>td   neotest debug nearest      (IDE: gutter debug icon)
"   <leader>ts   neotest summary toggle
"   <leader>to   neotest output for nearest
"   <leader>tO   neotest output panel
"   <leader>tS   neotest stop
"   <leader>tw   neotest watch toggle
"   <leader>or   overseer run task          (IDE: Run Anything / run config dropdown)
"   <leader>oR   overseer rerun last
"   <leader>oo   overseer task action menu
"   <leader>oc   overseer cancel running

" 5c) Typst — nvim-only namespace (lua/plugins/lang/typst.lua + lsp/tinymist.lua).
" Typst itself doesn't ship as a JetBrains-blessed language; preview/format/LSP
" all run through tinymist on the Neovim side. On JetBrains use the third-party
" "Typst" plugin if installed — its actions don't have stable IDs to map here.
"
"   <localleader>tp   :TypstPreview                   start preview (browser, live)
"   <localleader>tt   :TypstPreviewToggle             toggle preview server
"   <localleader>tP   :TypstPreviewStop               stop preview server
"   <localleader>ts   :TypstPreviewSyncCursor         scroll preview to cursor (one-shot)
"   <localleader>tF   :TypstPreviewFollowCursorToggle toggle live cursor follow
"
" Format (.typ) goes through conform → typstyle on save (tools/mason_ensure.lua),
" same gateway as every other filetype — <leader>ff still works.

" 5d) Scheme / Racket / Steel — nvim-only namespace (lua/plugins/lang/scheme.lua).
" The Lisp workflow is REPL-driven (Conjure on the Neovim side), structurally
" different from JetBrains' file/project edit-and-run model. JetBrains has no
" first-party Racket/Scheme/Steel plugin with stable Action IDs we can map to,
" and no equivalent of paredit slurp/barf. Documenting the asymmetry instead of
" inventing fragile bindings — same precedent as Flash Treesitter, Neotest, and
" the DAP step-keys above.
"
" Conjure (REPL eval) — ,c* prefix on Neovim, no IdeaVim equivalent:
"   ,cee   eval form at point         (no IDE counterpart — use SendSelectionToRepl
"                                      manually if the REPL plugin offers it)
"   ,cer   eval root form
"   ,cE    eval entire buffer
"   ,clg   open / focus REPL log
"   ,cqq   stop REPL session
"
" nvim-paredit (structural paren editing) — ,p* prefix on Neovim, no IdeaVim equivalent:
"   ,p>    slurp forwards (pull next form into current)
"   ,p<    barf forwards  (push last form out)
"   ,pP    slurp backwards
"   ,pB    barf backwards
"   ,pw    wrap element under cursor
"   ,pW    wrap enclosing form
"   ,pr    raise element
"   ,pR    raise form
"   ,pdf   delete form
"   ,pde   delete element
"   E/W/B/gE  next/prev element head/tail (replaces vim default WORD motions in lisp ft)
"   (/)    move to parent form start/end
"
" LSP for Racket / Guile / Steel: gd/gD/gi/gr/<leader>rn etc. all reuse the
" community g* defaults shared with every other LSP (lua/core/lsp.lua) — those
" already work on the IdeaVim side via JetBrains GotoDeclaration etc., so
" nothing extra to bind. Formatting (.rkt → raco fmt, .scm → schemat) goes
" through conform → <leader>ff on the Neovim side; on JetBrains use the third-
" party Racket plugin's Reformat action if installed.

" 6) Reformat
map <leader>F <Action>(CodeFormatGroup)
map <leader>ff <Action>(ReformatCode)
map <leader>fF <Action>(ShowReformatFileDialog)
map <leader>fS <Action>(osmedile.intellij.stringmanip.PopupChoiceAction)

" 7)  Mark — mirrors lua/plugins/edit/marks.lua
"
" Core bindings (mirrored on both sides):
nmap <leader>M <Action>(Bookmarks)
nmap <leader>mm <Action>(ToggleBookmark)
nmap <leader>mM <Action>(ToggleBookmarkWithMnemonic)
nmap <leader>mn <Action>(GotoNextBookmarkInEditor)
nmap <leader>mN <Action>(GotoPreviousBookmark)
"
" Search namespace — nvim-only (the <leader>s* namespace itself is nvim-only
" because IDE uses Search Everywhere); search by keyword, picker UI:
"   <leader>sm  → :BookmarksGoto      fuzzy picker over bookmarks
"                                     (telescope-backed, hard dep — see
"                                      lua/plugins/edit/marks.lua lines 38–52)
"
" nvim-only extras (no precise IdeaVim equivalent; the <leader>M IDE panel
" covers similar ground interactively):
"   <leader>ml  → :BookmarksLists     switch active list (nvim multi-list)
"   <leader>ma  → :BookmarksCommands  bookmark command palette
"   <leader>mg  → :BookmarksGrep      grep inside bookmarked files

" AI
map <leader>A <Action>(AIIntentionsActionGroup)

" Popups / 菜单

nnoremap <leader>y "+y
vnoremap <leader>y "+y
nnoremap <leader>p "+p
vnoremap <leader>p "+p

nnoremap <A-d> "_d
vnoremap <A-d> "_d
" 视觉模式下，J 和 K 移动选区
nmap zj <Action>(NextFoldingSection)
nmap zk <Action>(PreviousFoldingSection)

vnoremap J :move '>+1<CR>gv=gv
vnoremap K :move '<-2<CR>gv=gv

nmap ]d <Action>(GotoNextError)
nmap [d <Action>(GotoPreviousError)

" ===== Syntax-aware navigation & editing =====
" Mirrors lua/plugins/edit/textobjects.lua (nvim-treesitter-textobjects on the
" Neovim side). IDE actions cover what JetBrains exposes natively; kinds
" without a matching action stay nvim-only (listed at the bottom of this
" section so both sides share one source of truth).

" Bracket-prefix motions
nmap ]f <Action>(MethodDown)
nmap [f <Action>(MethodUp)
nmap ]c <Action>(VcsShowNextChangeMarker)
nmap [c <Action>(VcsShowPrevChangeMarker)

" Sibling swap (statement / argument).
" MoveStatementDown/Up is the same action IDE binds to Cmd+Shift+Down/Up.
" MoveElementRight/Left swaps a function argument with its neighbor.
nmap gss <Action>(MoveStatementDown)
nmap gsS <Action>(MoveStatementUp)
nmap gsa <Action>(MoveElementRight)
nmap gsA <Action>(MoveElementLeft)

" Incremental selection — grow/shrink to enclosing syntax node.
" <Action>(EditorSelectWord) through IdeaVim does NOT work: the dispatch
" resets the caret/selection model between calls, so the action's internal
" "extend further" state is lost and rapid presses all restart from cursor.
" Workaround: sethandler — let the IDE handle the key natively. Requires a
" one-time setup in IDE Preferences → Keymap:
"   Alt+W        → EditorSelectWord
"   Alt+Shift+W  → EditorUnSelectWord
" (IDE default is Opt+Up/Down on Mac; we rebind for parity with <A-w>/<A-W>.)
sethandler <A-w> a:ide
sethandler <A-W> a:ide

" nvim-only (no IDE action with the same granularity — intentionally unbound
" here):
"   ]l/[l ]L/[L    → @loop.outer start/end
"   ]i/[i          → @conditional.outer (if / match / switch)
"   ]C/[C          → @class.outer (GotoNextClass is project-wide, not buffer-local)
"   ]F/[F          → @function.outer end (MethodUp/Down has no end variant)
"   ]a/[a          → @parameter.outer
"   af/if ac/ic ai/ii al/il → treesitter-textobjects selections
"                    (argtextobj plugin already covers aa/ia on this side)
